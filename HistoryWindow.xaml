<Window x:Class="MangaMeeya_by_Jin.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="📜 열람 기록" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Icon="app.ico"
        Background="#FFF5F5F5">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 기록 목록 -->
        <DataGrid x:Name="HistoryDataGrid"
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="HistoryDataGrid_MouseDoubleClick"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#FFF0F0F0"
                  RowHeight="35"
                  FontSize="13">
            <DataGrid.Resources>
                <Style TargetType="DataGridRow">
                    <EventSetter Event="MouseDoubleClick" Handler="HistoryDataGrid_MouseDoubleClick"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="파일명" 
                                    Binding="{Binding FileName}" 
                                    Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="진행 페이지" 
                                    Binding="{Binding PageProgress}" 
                                    Width="1*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="마지막 본 시간" 
                                    Binding="{Binding LastViewedString}" 
                                    Width="1.5*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,10,0,0">
            <Button x:Name="OpenSelectedButton"
                    Content="📂 선택한 파일 열기"
                    Width="150" Height="40" Margin="5"
                    FontSize="13" FontWeight="Bold"
                    Background="#FF4CAF50" Foreground="White"
                    Cursor="Hand" BorderThickness="2"
                    BorderBrush="#FF2E7D32"
                    Click="OpenSelectedButton_Click"/>
            <Button x:Name="DeleteSelectedButton"
                    Content="🗑 선택 삭제"
                    Width="110" Height="40" Margin="5"
                    FontSize="13" FontWeight="Bold"
                    Background="#FFF44336" Foreground="White"
                    Cursor="Hand" BorderThickness="2"
                    BorderBrush="#FFB71C1C"
                    Click="DeleteSelectedButton_Click"/>
            <Button x:Name="ClearAllButton"
                    Content="🗑 전체 삭제"
                    Width="110" Height="40" Margin="5"
                    FontSize="13" FontWeight="Bold"
                    Background="#FF9E9E9E" Foreground="White"
                    Cursor="Hand" BorderThickness="2"
                    BorderBrush="#FF757575"
                    Click="ClearAllButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
