<Window x:Class="MangaMeeya_by_Jin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MangaMeeya by Jin - 만화 ZIP 뷰어" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F0F0"
        Icon="app.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- 이미지 표시 영역 -->
        <Border Grid.Row="0" Background="#FF000000">
            <Image x:Name="MangaImage" 
                   Stretch="Uniform"/>
        </Border>

        <!-- 하단 컨트롤 패널 -->
        <Grid Grid.Row="1" Background="#FFE8E8E8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 첫 번째 줄: 버튼들 -->
            <StackPanel Grid.Row="0" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center"
                        Margin="10">
                
                <!-- 파일 열기 버튼 -->
                <Button x:Name="OpenButton" 
                        Content="📁 ZIP 파일 열기" 
                        Width="130" 
                        Height="45" 
                        Margin="5"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="OpenButton_Click"
                        Background="#FF4CAF50"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="2"
                        BorderBrush="#FF2E7D32"
                        Padding="5"/>

                <!-- 이전 버튼 -->
                <Button x:Name="PrevButton" 
                        Content="◀ 이전" 
                        Width="100" 
                        Height="45" 
                        Margin="5"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="PrevButton_Click"
                        Background="#FF2196F3"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="2"
                        BorderBrush="#FF0D47A1"
                        Padding="5"/>

                <!-- 페이지 정보 -->
                <TextBlock x:Name="PageLabel" 
                           Text="0/0" 
                           Width="80" 
                           Height="45" 
                           Margin="5"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Background="White"
                           Padding="5"/>

                <!-- 다음 버튼 -->
                <Button x:Name="NextButton" 
                        Content="다음 ▶" 
                        Width="100" 
                        Height="45" 
                        Margin="5"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="NextButton_Click"
                        Background="#FF2196F3"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="2"
                        BorderBrush="#FF0D47A1"
                        Padding="5"/>

                <!-- 전체화면 버튼 -->
                <Button x:Name="FullscreenButton" 
                        Content="🖥 전체화면" 
                        Width="110" 
                        Height="45" 
                        Margin="5"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="FullscreenButton_Click"
                        Background="#FF9C27B0"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="2"
                        BorderBrush="#FF6A1B9A"
                        Padding="5"/>

                <!-- 언어 선택 ComboBox -->
                <ComboBox x:Name="LanguageComboBox"
                          Width="100"
                          Height="45"
                          Margin="5"
                          FontSize="14"
                          FontWeight="Bold"
                          VerticalContentAlignment="Center"
                          HorizontalContentAlignment="Center"
                          SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBoxItem Content="한국어" Tag="ko"/>
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="中文" Tag="zh"/>
                    <ComboBoxItem Content="日本語" Tag="ja"/>
                </ComboBox>

                <!-- 기록 버튼 -->
                <Button x:Name="HistoryButton"
                        Content="📜 기록"
                        Width="90"
                        Height="45"
                        Margin="5"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="HistoryButton_Click"
                        Background="#FFFF9800"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="2"
                        BorderBrush="#FFE65100"
                        Padding="5"/>
            </StackPanel>

            <!-- 두 번째 줄: 파일명 및 제스처 안내 -->
            <Grid Grid.Row="1" Margin="20,0,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FileLabel" 
                           Grid.Column="0"
                           Text="파일: 없음" 
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           FontSize="12"
                           Foreground="#FF333333"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,10,0"/>
                <StackPanel Grid.Column="1" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="GestureWheelText"
                               Text="🖱 휠/좌우 드래그: 이전/다음 페이지" 
                               FontSize="11" 
                               Foreground="#FF666666" 
                               TextAlignment="Right"/>
                    <TextBlock x:Name="GestureUpText"
                               Text="🖱 위로 드래그: 전체화면 토글" 
                               FontSize="11" 
                               Foreground="#FF666666" 
                               TextAlignment="Right" 
                               Margin="0,2,0,0"/>
                    <TextBlock x:Name="GestureDownText"
                               Text="🖱 아래로 드래그: 전체화면 해제" 
                               FontSize="11" 
                               Foreground="#FF666666" 
                               TextAlignment="Right" 
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
