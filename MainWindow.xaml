<Window x:Class="MangaMeeya.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MangaMeeya - 만화 ZIP 뷰어" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F0F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- 이미지 표시 영역 -->
        <Border Grid.Row="0" Background="#FF000000">
            <Image x:Name="MangaImage" 
                   Stretch="Uniform"/>
        </Border>

        <!-- 하단 컨트롤 패널 -->
        <Grid Grid.Row="1" Background="#FFE8E8E8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 첫 번째 줄: 버튼들 -->
            <StackPanel Grid.Row="0" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center"
                        Margin="10">
                
                <!-- 파일 열기 버튼 -->
                <Button x:Name="OpenButton" 
                        Content="📁 ZIP 파일 열기" 
                        Width="130" 
                        Height="45" 
                        Margin="5"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="OpenButton_Click"
                        Background="#FF4CAF50"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="2"
                        BorderBrush="#FF2E7D32"
                        Padding="5"/>

                <!-- 이전 버튼 -->
                <Button x:Name="PrevButton" 
                        Content="◀ 이전" 
                        Width="100" 
                        Height="45" 
                        Margin="5"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="PrevButton_Click"
                        Background="#FF2196F3"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="2"
                        BorderBrush="#FF0D47A1"
                        Padding="5"/>

                <!-- 페이지 정보 -->
                <TextBlock x:Name="PageLabel" 
                           Text="0/0" 
                           Width="80" 
                           Height="45" 
                           Margin="5"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Background="White"
                           Padding="5"/>

                <!-- 다음 버튼 -->
                <Button x:Name="NextButton" 
                        Content="다음 ▶" 
                        Width="100" 
                        Height="45" 
                        Margin="5"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="NextButton_Click"
                        Background="#FF2196F3"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="2"
                        BorderBrush="#FF0D47A1"
                        Padding="5"/>

                <!-- 전체화면 버튼 -->
                <Button x:Name="FullscreenButton" 
                        Content="🖥 전체화면" 
                        Width="110" 
                        Height="45" 
                        Margin="5"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="FullscreenButton_Click"
                        Background="#FF9C27B0"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="2"
                        BorderBrush="#FF6A1B9A"
                        Padding="5"/>
            </StackPanel>

            <!-- 두 번째 줄: 파일명 표시 -->
            <TextBlock x:Name="FileLabel" 
                       Grid.Row="1"
                       Text="파일: 없음" 
                       Margin="10"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Foreground="#FF333333"/>
        </Grid>
    </Grid>
</Window>
